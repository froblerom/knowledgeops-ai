# KnowledgeOps-AI Local Development Environment Template
#
# USAGE:
#   cp .env.example .env
#   Edit .env and set a strong local SA password before first use.
#
# IMPORTANT:
#   Never commit .env to source control.
#   This file (.env.example) contains safe placeholder values only.
#   It contains no real secrets, no production connection strings,
#   and no real customer, employee, or client data.

# ------------------------------------------------------------------
# SQL Server (Docker Compose — sqlserver service)
# ------------------------------------------------------------------

# SA password for the local SQL Server container.
# Must meet SQL Server complexity requirements:
#   - Minimum 8 characters
#   - Uppercase, lowercase, digit, and symbol
# Replace this placeholder with your own local value before first use.
# This placeholder is NOT a real password and must not be used in production.
KNOWLEDGEOPS_SQL_PASSWORD=Change_this_local_password_123!

# Host port for SQL Server container. Change if port 1433 is already in use locally.
KNOWLEDGEOPS_SQL_PORT=1433

# Local database name (used when EF Core migrations are introduced in a later sprint).
KNOWLEDGEOPS_SQL_DATABASE=KnowledgeOpsLocal

# ------------------------------------------------------------------
# Connection String (for future EF Core migration sprint)
# ------------------------------------------------------------------

# Full local connection string for API/Worker when EF Core is implemented.
# Not required until persistence is introduced. Provided here as a forward reference.
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=KnowledgeOpsLocal;User Id=sa;Password=Change_this_local_password_123!;TrustServerCertificate=True;Encrypt=True

# ------------------------------------------------------------------
# AI Provider (fake mode — no live provider required)
# ------------------------------------------------------------------

# Set to "Fake" for local development without a real AI provider.
# This is the default and is required for normal automated testing and CI.
# Only change this to "AzureOpenAI" or "OpenAI" if you are manually
# testing live AI provider behavior; real keys are never required.
KNOWLEDGEOPS_AI_PROVIDER_MODE=Fake

# ------------------------------------------------------------------
# Local Document Storage (Sprint 11+)
# ------------------------------------------------------------------

# Local path where uploaded documents are stored during development.
# Default: .local/storage/documents (relative to repository root).
# This directory is excluded from source control by .gitignore.
# Override only if the default path conflicts with your local setup.
# Storage__LocalDocumentsPath=.local/storage/documents

# ------------------------------------------------------------------
# Worker (Sprint 12+)
# ------------------------------------------------------------------

# Worker document polling interval in seconds. Default: 10.
# Override if a different interval is needed for local testing.
# Worker__PollingIntervalSeconds=10

# Live provider keys are NOT required. Do not add real keys to .env.example.
# Add them to .env only when manually testing live provider integration.
# KNOWLEDGEOPS_AZURE_OPENAI_ENDPOINT=
# KNOWLEDGEOPS_AZURE_OPENAI_API_KEY=
# KNOWLEDGEOPS_OPENAI_API_KEY=
